PORT=5000
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=edel_db
JWT_SECRET=change_me
JWT_EXPIRE=30d
NODE_ENV=development

# Public web origin used in password reset links
PUBLIC_WEB_BASE_URL=http://localhost:5500

# SendPulse API
# Use the API ID/Secret from Settings > API in SendPulse.
SENDPULSE_API_ID=
SENDPULSE_API_SECRET=
# Use a verified sender email in SendPulse.
SENDPULSE_FROM_NAME=
SENDPULSE_FROM_EMAIL=

# Admin Credentials (for seed script)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
ADMIN_PHONE=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# BigDataCloud Geolocation API
BIGDATACLOUD_API_KEY=
BIGDATACLOUD_BASE_URL=https://api.bigdatacloud.net
