PORT=5000
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=edel_db
JWT_SECRET=change_me
JWT_EXPIRE=30d
NODE_ENV=development

# Public web origin used in password reset links
PUBLIC_WEB_BASE_URL=http://localhost:5500

# SendPulse API
# Use the API ID/Secret from Settings > API in SendPulse.
SENDPULSE_API_ID=your_sendpulse_api_id
SENDPULSE_API_SECRET=your_sendpulse_api_secret
# Use a verified sender email in SendPulse.
SENDPULSE_FROM_NAME=E-del
SENDPULSE_FROM_EMAIL=no-reply@yourdomain.com

# Admin Credentials (for seed script)
ADMIN_EMAIL=admin@edel.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_FULL_NAME=Edel Admin
ADMIN_PHONE=08000000000

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
